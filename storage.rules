rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isImageWithinLimit() {
      // request.resource is null on delete; size/type only apply to uploads.
      return request.resource == null
        || (request.resource.size <= 5 * 1024 * 1024
            && request.resource.contentType.matches('image/.*'));
    }

    function canEditRestaurant(restaurantId) {
      let ownerUid = firestore.get(/databases/(default)/documents/restaurants/$(restaurantId)).data.uid;
      return ownerUid == request.auth.uid
        || (ownerUid == request.auth.token.parentUid
            && restaurantId in firestore.get(/databases/(default)/documents/admins/$(ownerUid)/children/$(request.auth.uid)).data.restaurantLists);
    }

    match /images/restaurants/{restaurantId}/{userId}/cover.jpg {
      allow write: if request.auth.uid == userId && isImageWithinLimit() && canEditRestaurant(restaurantId);
      allow read;
    }
    match /images/restaurants/{restaurantId}/{userId}/profile.jpg {
      allow write: if request.auth.uid == userId && isImageWithinLimit() && canEditRestaurant(restaurantId);
      allow read;
    }
    match /images/restaurants/{restaurantId}/menus/{menuId}/{userId}/item.jpg {
      allow write: if request.auth.uid == userId && isImageWithinLimit() && canEditRestaurant(restaurantId);
      allow read;
    }

    match /images/restaurants/{restaurantId}/{userId}/resize/{size}/cover.jpg {
      allow read;
    }
    match /images/restaurants/{restaurantId}/{userId}/resize/{size}/profile.jpg {
      allow read;
    }
    match /images/restaurants/{restaurantId}/menus/{menuId}/{userId}/resize/{size}/item.jpg {
      allow read;
    }

    match /images/restaurants/{restaurantId}/cover.jpg {
      allow write: if false;
      allow read;
    }
    match /images/restaurants/{restaurantId}/profile.jpg {
      allow write: if false;
      allow read;
    }
    match /images/restaurants/{restaurantId}/menus/{menuId}/item.jpg {
      allow write: if false;
      allow read;
    }

    match /{allPaths=**} {
      allow read, write: if false
    }
  }
}
