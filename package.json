{
  "name": "OwnPlate",
  "version": "4.0.1",
  "private": true,
  "description": "OwnPlate - Delicious food",
  "author": "OwnPlate developer team",
  "type": "module",
  "scripts": {
    "start": "vite",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "vite build && cp dist/index.html functions/templates/index.html",
    "batch": "babel-node --presets @babel/env",
    "lint": "yarn run dumpi18n && eslint src --cache --cache-location node_modules/.cache/eslint/",
    "dumpi18n": "npx tsx batch/i18n-dump.ts",
    "customclaims": "babel-node --presets @babel/env  ./batch/customclaims.js",
    "format": "prettier --write '{src/**/*,*}.{js,ts,vue,json,css}'",
    "makenews": "npx tsx ./batch/news.js",
    "user": "babel-node --presets @babel/env  ./batch/user.js"
  },
  "dependencies": {
    "@chenfengyuan/vue-qrcode": "^2.0.0",
    "@line/liff": "^2.29.1",
    "@sentry/tracing": "^7.120.4",
    "@sentry/vue": "^10.65.0",
    "@unhead/vue": "^3.1.8",
    "chart.js": "^4.5.1",
    "cookie": "^2.0.1",
    "crypto-js": "^4.1.1",
    "firebase": "12.16.0",
    "google-libphonenumber": "^3.2.44",
    "markdown-it": "^14.3.0",
    "moment": "^2.29.4",
    "moment-timezone": "0.6.2",
    "pdfmake": "0.3.11",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "query-string": "^9.4.1",
    "unplugin-vue-markdown": "^32.0.0",
    "validator": "^13.15.35",
    "vite": "8.1.4",
    "vue": "^3.5.39",
    "vue-chart-3": "^3.1.8",
    "vue-clipboard3": "^2.0.0",
    "vue-i18n": "11.4.6",
    "vue-router": "^5.1.0",
    "vue-social-sharing": "^4.0.0-alpha4",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/eslint-plugin-vue-i18n": "^4.5.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/crypto-js": "^4.1.1",
    "@types/google-libphonenumber": "^7.4.27",
    "@types/google.maps": "^3.65.2",
    "@types/gtag.js": "^0.0.20",
    "@types/pdfmake": "0.3.3",
    "@types/query-string": "^6.3.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "firebase-admin": "^14.1.0",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "raw-loader": "^4.0.2",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite-plugin-checker": "^0.14.4",
    "vue-eslint-parser": "^10.4.1",
    "yaml-eslint-parser": "^2.1.0"
  }
}
